{
  "compilerOptions": {
    "outDir": "./dist/",
    "baseUrl": ".",
    "paths": {
        "src/*": ["src/*"]
    },
    "experimentalDecorators": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "module": "commonjs",
    "target": "es5",
    "jsx": "react",
    "allowJs": true,
    "types": [
    ],
    "lib": [
      "es2016",
      "dom"
    ],
  },
  "include": [
    "src"
  ]
}